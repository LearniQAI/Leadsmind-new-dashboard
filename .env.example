# ── SUPABASE ─────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── AUTH & SECURITY ───────────────────────────────
CRON_SECRET=generate-a-random-32-char-string
WEBHOOK_SIGNING_SECRET=your-webhook-signing-secret
JWT_SECRET=your-jwt-secret
JWT_SECRET_KEY=your-jwt-secret-key
KYC_ENCRYPTION_KEY=your-kyc-encryption-key
ENCRYPTION_KEY=your-encryption-key
POPIA_CONSENT_SALT=your-popia-consent-salt
META_WEBHOOK_VERIFY_TOKEN=your-meta-webhook-verify-token
RESEND_WEBHOOK_SECRET=your-resend-webhook-secret
AVATAR_GENERATOR_WEBHOOK_SECRET=generate-a-random-32-char-string
MOCK_DNS_VERIFICATION=false
MOCK_DB=false

# ── NEXT.JS ───────────────────────────────────────
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=https://your-app-domain.com
NEXT_PUBLIC_APP_URL=https://your-app-domain.com
NEXT_PUBLIC_DEFAULT_WORKSPACE_ID=your-default-workspace-id
NEXT_PUBLIC_ENFORCE_PLAN_LIMITS=true
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn
NODE_ENV=development

# ── AI SERVICES ──────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=your-gemini-api-key
ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# ── PAYMENTS ─────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your-stripe-key
STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
# Stripe Connect OAuth application client_id (Stripe Dashboard -> Connect -> Settings,
# format ca_...). The token exchange itself reuses STRIPE_SECRET_KEY above as the implicit
# client_secret (Stripe SDK convention) — no separate Connect secret is needed.
STRIPE_CONNECT_CLIENT_ID=ca_your-stripe-connect-client-id
STRIPE_RISE_MONTHLY_PRICE_ID=price_your-rise-monthly-price-id
STRIPE_RISE_ANNUAL_PRICE_ID=price_your-rise-annual-price-id
STRIPE_SURGE_MONTHLY_PRICE_ID=price_your-surge-monthly-price-id
STRIPE_SURGE_ANNUAL_PRICE_ID=price_your-surge-annual-price-id
STRIPE_INFINITY_MONTHLY_PRICE_ID=price_your-infinity-monthly-price-id
STRIPE_INFINITY_ANNUAL_PRICE_ID=price_your-infinity-annual-price-id
STRIPE_DYNASTY_MONTHLY_PRICE_ID=price_your-dynasty-monthly-price-id
STRIPE_DYNASTY_ANNUAL_PRICE_ID=price_your-dynasty-annual-price-id
PAYFAST_MERCHANT_ID=your-payfast-merchant-id
PAYFAST_MERCHANT_KEY=your-payfast-merchant-key
PAYFAST_PASSPHRASE=your-payfast-passphrase
PAYFAST_URL=https://secure.payfast.co.za/eng/process

# ── EMAIL ─────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=no-reply@yourdomain.com

# ── SMS / VOICE ───────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15551234567
TWILIO_API_KEY=your-twilio-api-key
TWILIO_API_SECRET=your-twilio-api-secret

# ── STORAGE / MEDIA ───────────────────────────────
CLOUDINARY_URL=cloudinary://your-cloudinary-url
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ── MISC / INTEGRATIONS ───────────────────────────
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key
NEXT_PUBLIC_META_APP_ID=your-meta-app-id
